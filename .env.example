# ============================================================
#  FOREMAN — Konfigurations-Vertrag (Beispiel, OHNE Secrets)
#  Echte Werte gehören in .env (gitignored, nie committen).
#  Variablennamen spiegeln src/foreman/config.py (Pydantic-Settings).
# ============================================================

# --- App ---
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# --- PostgreSQL + TimescaleDB ---
# docker compose nutzt POSTGRES_* für den DB-Service; die App liest DATABASE_URL.
POSTGRES_USER=foreman
POSTGRES_PASSWORD=__pw__
POSTGRES_DB=foreman
DATABASE_URL=postgresql+asyncpg://foreman:__pw__@localhost:5432/foreman

# --- Auth (JWT) — im Produktionsbetrieb Pflicht, JWT_SECRET >= 32 Byte ---
JWT_SECRET=__bitte_setzen_min_32_byte__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Gedächtnis-Substrat (NEXUS-Anbindung, externer Dienst hinter HTTP-API) ---
# Datenaufnahme läuft auch ohne Substrat (Fallback). Leer = Smoke übersprungen.
# Zugangsdaten NIEMALS hier eintragen — nur in der echten .env.
# RAILWAY/ETAPPE 1: LEER LASSEN. Das Substrat (dedizierte FOREMAN-NEXUS) kommt
# erst in Etappe 2 dazu; bis dahin läuft die H-Sektion/Gedächtnis im Fallback.
SUBSTRATE_BASE_URL=
SUBSTRATE_TOKEN=
SUBSTRATE_TIMEOUT_S=10
SUBSTRATE_NAMESPACE=foreman

# --- Modell-Gateway (F-LLM; eigene LLMGateway-Abstraktion über LiteLLM, §13) ---
# Reasoner sehen nur LLMGateway — LiteLLM ist Implementierungsdetail in backends.py.
# Default = RAILWAY/ETAPPE 1: cloud_only (KEIN Ollama im Container) — dann
# FOREMAN_LLM_CLOUD_API_KEY mit dem Anthropic-Key füllen (Railway-Secret).
# Lokal mit Ollama: auf local_first umstellen.
FOREMAN_LLM_PRIORITY=cloud_only              # local_first | cloud_first | local_only | cloud_only
FOREMAN_LLM_LOCAL_BASE_URL=http://localhost:11434   # Ollama (Qwen3 lokal), nur bei *local*-Priorität
FOREMAN_LLM_LOCAL_MODEL=ollama/qwen3:14b
FOREMAN_LLM_CLOUD_MODEL=anthropic/claude-sonnet-4-5
FOREMAN_LLM_CLOUD_API_KEY=__bitte_setzen__   # Anthropic-Key; bei cloud_only Pflicht (leer = nur lokal möglich)

# --- Embedding-Provider (F-SEM; semantische Notiz-Suche, GROUND_TRUTH §15) ---
# Eigene Schicht parallel zum LLM-Gateway (Embeddings != Completion).
# Default = RAILWAY/ETAPPE 1: st_only — ohne Ollama greift der sentence-transformers-
# Fallback (BAAI/bge-m3 auf CPU, schwer/langsam); st_only spart den toten Ollama-
# Versuch-Timeout. F-SEM darf in Etappe 1 optional/degradiert sein.
# Lokal mit Ollama: auf ollama_first umstellen. Dauerlast später über Ollama/GPU.
FOREMAN_EMBED_PRIORITY=st_only               # ollama_first | st_first | ollama_only | st_only
FOREMAN_EMBED_LOCAL_BASE_URL=http://localhost:11434   # Ollama (bge-m3)
FOREMAN_EMBED_MODEL=bge-m3                    # Ollama-Embedding-Modell (1024-dim)
FOREMAN_EMBED_ST_MODEL=BAAI/bge-m3           # sentence-transformers-Alternative (lazy)
FOREMAN_EMBED_ST_DEVICE=cpu
FOREMAN_EMBED_DIMENSION=1024                  # muss auf worker_notes.embedding vector(1024) passen
FOREMAN_EMBED_NORMALIZE=true                  # L2-Normalisierung (Cosine/HNSW)
FOREMAN_EMBED_REQUEST_TIMEOUT_S=30
FOREMAN_EMBED_BATCH_SIZE=32                   # Ingest-/Backfill-Batch

# --- Pseudonymisierung (HMAC über users.id, GROUND_TRUTH §8) ---
# Schlüssel je Version als 32-Byte-Hex erzeugen: openssl rand -hex 32
FOREMAN_PSEUDO_KEY_VERSION=v1
FOREMAN_PSEUDO_KEY_VERSIONS=v1
FOREMAN_PSEUDO_KEY_v1=__32_byte_hex__
FOREMAN_PSEUDO_TENANT=default

# --- MCP-Schnittstelle (F7; read-only Model-Context-Protocol-Server, GROUND_TRUTH §17) ---
# Eigenständiger Server (eigener Port, eigener Token — getrennt vom Plattform-JWT).
# Token erzeugen: openssl rand -hex 32. Im Produktionsbetrieb Pflicht (>= 32 Byte);
# leer/zu kurz => der Server weist alles ab (Fail-Closed) bzw. bricht den Start ab.
FOREMAN_MCP_TOKEN=__bitte_setzen_min_32_byte__   # leer = Fail-Closed (kein Zugriff)
FOREMAN_MCP_HOST=0.0.0.0                          # remote erreichbar für Drittsysteme
FOREMAN_MCP_PORT=8081
FOREMAN_MCP_RATE_LIMIT_CAPACITY=120               # Token-Bucket gegen Abruf-Last
FOREMAN_MCP_RATE_LIMIT_REFILL_PER_S=4

# ============================================================
#  Frontend-Service (Deploy) — NICHT vom Backend-Prozess gelesen.
#  Diese zwei Variablen gehören auf den FRONTEND-Service (Next.js-BFF), hier nur
#  als Deploy-Vertrag dokumentiert. Verdrahtung Schritt für Schritt in DEPLOY.md.
# ============================================================
# Server-seitige Backend-Basis-URL des BFF-Proxys (app/api/v1/[...path], /me,
# ws-ticket). NIE an den Browser ausgeliefert. Lokal: http://localhost:8000.
# RAILWAY: INTERNE Adresse über private networking, z. B.
#   http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:${{backend.PORT}}
FOREMAN_API_URL=http://localhost:8000

# Browser-seitige Live-WebSocket-URL. NEXT_PUBLIC_* wird ZUR BUILD-ZEIT ins Bundle
# gebacken → vor dem FE-Build setzen. Leer = Übersicht bleibt auf HTTP-Erstbild.
# Lokal: ws://localhost:8000/api/v1/ws. RAILWAY: ÖFFENTLICHE wss://-Adresse, z. B.
#   wss://<backend-public-domain>/api/v1/ws
NEXT_PUBLIC_FOREMAN_WS_URL=
