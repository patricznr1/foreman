# ============================================================
#  FOREMAN — Konfigurations-Vertrag (Beispiel, OHNE Secrets)
#  Echte Werte gehören in .env (gitignored, nie committen).
# ============================================================

# --- App ---
FOREMAN_ENV=development          # development | staging | production
FOREMAN_HOST=0.0.0.0
FOREMAN_PORT=8000
LOG_LEVEL=INFO

# --- Auth (JWT) ---
JWT_SECRET=__bitte_setzen__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- PostgreSQL + TimescaleDB ---
DATABASE_URL=postgresql+asyncpg://foreman:__pw__@localhost:5432/foreman

# --- Gedächtnis-Substrat (externer Dienst, wie eine DB konsumiert) ---
# Zugangsdaten NIEMALS hier eintragen — nur in der echten .env.
NEXUS_API_URL=https://__substrat_host__/api
NEXUS_API_KEY=__bitte_setzen__

# --- Modell-Gateway (LiteLLM) ---
LLM_LOCAL_BASE_URL=http://localhost:11434   # Ollama (Qwen3 lokal)
LLM_CLOUD_API_KEY=__bitte_setzen__          # Cloud-Fallback (Anthropic)
LLM_DEFAULT_BACKEND=local                   # local | cloud
